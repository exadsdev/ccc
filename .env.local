# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-at-least-32-characters-long"

# Admin credentials (เปลี่ยนก่อนใช้งาน production)
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="your-secure-admin-password"

# Site Config
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
NEXT_PUBLIC_SITE_NAME="AdsAccount Pro - จำหน่ายบัญชีโฆษณา Google Agency"
NEXT_PUBLIC_LINE_ID="@yourlineid"
NEXT_PUBLIC_TELEGRAM="@yourtelegram"
NEXT_PUBLIC_EMAIL="contact@yourdomain.com"
